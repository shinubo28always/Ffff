{
  "name": "LinkShareBot",
  "description": "A Telegram bot to share and manage channel links with auto-approval features.",
  "keywords": [
    "telegram",
    "bot",
    "link-share",
    "pyrogram"
  ],
  "repository": "https://github.com/yourusername/LinkShareBot",
  "env": {
    "TG_BOT_TOKEN": {
      "description": "Your Bot token, Get it from @Botfather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "API_ID": {
      "description": "Your APP ID from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Your API HASH from my.telegram.org",
      "required": true
    },
    "DB_URL": {
      "description": "MongoDB connection string",
      "required": true
    },
    "DB_NAME": {
      "description": "MongoDB database name",
      "value": "Links-Share",
      "required": false
    },
    "DATABASE_CHANNEL": {
      "description": "Private channel ID for link storage",
      "required": true
    },
    "ADMINS": {
      "description": "Space separated list of admin user IDs",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
